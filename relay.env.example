# Copy to .env on RU relay node before running docker-compose.relay.yml
RELAY_API_KEY=change_me_long_random_key
RELAY_PORT=7070
RELAY_CORS_ORIGIN=*

# Optional proxy on RU node (if needed)
NALOGO_PROXY_URL=

# Relay runtime tuning
NALOGO_BRIDGE_ENABLED=true
NALOGO_BRIDGE_ONLY=true
NALOGO_BRIDGE_CREATE_ATTEMPTS=3
NALOGO_BRIDGE_TEST_ATTEMPTS=3
NALOGO_BRIDGE_RETRY_BASE_MS=1200
NALOGO_BRIDGE_PY_ATTEMPTS=3
NALOGO_BRIDGE_PY_RETRY_BASE_MS=1200
NALOGO_BRIDGE_PY_AUTH_TIMEOUT_MS=30000
NALOGO_BRIDGE_PY_CREATE_TIMEOUT_MS=45000
NALOGO_BRIDGE_PROCESS_OVERHEAD_MS=7000
NALOGO_BRIDGE_PROCESS_MAX_TIMEOUT_MS=120000
NALOGO_NATIVE_FALLBACK_ON_BRIDGE_ERROR=true

