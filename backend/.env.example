# STEALTHNET 3.0 — Backend (для локальной разработки)
# В Docker все переменные приходят из корневого .env через docker-compose.yml

NODE_ENV=development
PORT=5001

# PostgreSQL
DATABASE_URL=postgresql://stealthnet:password@localhost:5432/stealthnet

# JWT (минимум 32 символа)
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Первый админ
INIT_ADMIN_EMAIL=admin@stealthnet.local
INIT_ADMIN_PASSWORD=

# Remnawave API
REMNA_API_URL=https://panel.example.com
REMNA_ADMIN_TOKEN=

# CORS
CORS_ORIGIN=http://localhost:5173

# Internal API key for bot broadcast endpoint (/api/public/broadcast-targets)
BOT_INTERNAL_API_KEY=

# Auto backup worker (hourly by default)
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_MS=3600000

# Python bridge for Nalogovich SDK (enabled by default)
NALOGO_BRIDGE_ENABLED=true
NALOGO_BRIDGE_ONLY=true
NALOGO_BRIDGE_BIN=python3
NALOGO_BRIDGE_PATH=./scripts/nalogo_bridge.py
# Optional SOCKS proxy for NaloGO:
# socks5://user:pass@host:port
# or tg://socks?server=host&port=1080&user=user&pass=pass
NALOGO_PROXY_URL=
