# STEALTHNET 3.0 — Backend (для локальной разработки)
# В Docker все переменные приходят из корневого .env через docker-compose.yml

NODE_ENV=development
PORT=5001

# PostgreSQL
DATABASE_URL=postgresql://stealthnet:password@localhost:5432/stealthnet

# JWT (минимум 32 символа)
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Первый админ
INIT_ADMIN_EMAIL=admin@stealthnet.local
INIT_ADMIN_PASSWORD=

# Remnawave API
REMNA_API_URL=https://panel.example.com
REMNA_ADMIN_TOKEN=
# Optional tuning for Remna HTTP retries/timeouts
REMNA_FETCH_TIMEOUT_MS=15000
REMNA_FETCH_RETRY_ATTEMPTS=3
REMNA_FETCH_RETRY_BASE_MS=350

# CORS
CORS_ORIGIN=http://localhost:5173

# Internal API key for bot broadcast endpoint (/api/public/broadcast-targets)
BOT_INTERNAL_API_KEY=

# Auto backup worker (hourly by default)
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_MS=3600000

# Python bridge for Nalogovich SDK (enabled by default)
NALOGO_BRIDGE_ENABLED=true
NALOGO_BRIDGE_ONLY=true
NALOGO_BRIDGE_BIN=python3
NALOGO_BRIDGE_PATH=./scripts/nalogo_bridge.py
# Optional bridge retries for transient disconnects/timeouts
NALOGO_BRIDGE_CREATE_ATTEMPTS=2
NALOGO_BRIDGE_TEST_ATTEMPTS=2
NALOGO_BRIDGE_RETRY_BASE_MS=1200
# Internal retries inside Python bridge process (for "Server disconnected"/timeouts)
NALOGO_BRIDGE_PY_ATTEMPTS=2
NALOGO_BRIDGE_PY_RETRY_BASE_MS=800
# Hard timeouts inside Python bridge for Nalogovich calls
NALOGO_BRIDGE_PY_AUTH_TIMEOUT_MS=15000
NALOGO_BRIDGE_PY_CREATE_TIMEOUT_MS=20000
# Extra startup/teardown budget for bridge subprocess timeout calculation
NALOGO_BRIDGE_PROCESS_OVERHEAD_MS=5000
# Upper bound for bridge subprocess timeout (to avoid long hangs)
NALOGO_BRIDGE_PROCESS_MAX_TIMEOUT_MS=60000
# If true, backend tries native NaloGO HTTP flow when python bridge fails
NALOGO_NATIVE_FALLBACK_ON_BRIDGE_ERROR=true
# Optional remote relay (RU node) for check creation/auth:
# if NALOGO_REMOTE_RELAY_URL is set, backend will try relay first.
NALOGO_REMOTE_RELAY_URL=
# Optional bearer for protected relay
NALOGO_REMOTE_RELAY_BEARER=
# Optional key for protected relay (same as bearer secret)
NALOGO_REMOTE_RELAY_KEY=
NALOGO_REMOTE_RELAY_TIMEOUT_MS=60000
# If true, do only remote relay (no local fallback in DE panel)
NALOGO_REMOTE_RELAY_ONLY=false
# Optional SOCKS proxy for NaloGO:
# socks5://user:pass@host:port
# or tg://socks?server=host&port=1080&user=user&pass=pass
NALOGO_PROXY_URL=
